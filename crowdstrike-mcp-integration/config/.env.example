# CrowdStrike Falcon MCP Configuration
# Copy this to .env and configure your actual credentials

# Required Configuration
FALCON_CLIENT_ID=your-crowdstrike-client-id
FALCON_CLIENT_SECRET=your-crowdstrike-client-secret
FALCON_BASE_URL=https://api.crowdstrike.com

# Optional Configuration
FALCON_MCP_MODULES=detections,incidents,intel,spotlight,hosts,idp,ioc,ngsiem
FALCON_MCP_TRANSPORT=stdio
FALCON_MCP_DEBUG=false
FALCON_MCP_HOST=127.0.0.1
FALCON_MCP_PORT=8000
FALCON_MCP_STATELESS_HTTP=false

# SecurityAgents Integration Settings
SECURITY_AGENTS_WORKSPACE=/Users/sonny/security-assessment
INTEGRATION_LOG_LEVEL=INFO