# CrowdStrike MCP Integration Configuration

# CrowdStrike Falcon API Credentials
CROWDSTRIKE_CLIENT_ID=your-falcon-client-id-here
CROWDSTRIKE_CLIENT_SECRET=your-falcon-client-secret-here
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com

# MCP Configuration
MCP_TRANSPORT=stdio
MCP_SERVER_COMMAND=falcon-mcp
MCP_TIMEOUT=300

# Agent Configuration
ALPHA_4_ENABLED=true
GAMMA_ENABLED=true
BETA_4_ENABLED=true
DELTA_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=crowdstrike_mcp.log

# Database
DB_PATH=./mcp_integration.db

# Performance
COMMAND_TIMEOUT=300
LONG_RUNNING_TIMEOUT=3600