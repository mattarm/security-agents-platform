# SecurityAgents Development Environment Configuration
# Copy this file to terraform.tfvars and customize for your environment

# AWS Configuration
aws_region = "us-east-1"  # Primary Bedrock region

# IAM Configuration - Replace with your actual ARNs
admin_principal_arns = [
  "arn:aws:iam::123456789012:user/security-admin",
  "arn:aws:iam::123456789012:role/SecurityAdminRole"
]

dev_principal_arns = [
  "arn:aws:iam::123456789012:user/dev-team-member-1",
  "arn:aws:iam::123456789012:user/dev-team-member-2"
]

# Alert Configuration - Replace with your actual email addresses
security_alert_emails = [
  "security-team@company.com",
  "alpha-1-team@company.com"
]

operational_alert_emails = [
  "devops@company.com",
  "infrastructure@company.com"
]

cost_alert_emails = [
  "finance@company.com",
  "infrastructure-manager@company.com"
]

# Integration Configuration (Optional)
# slack_webhook_url = "https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK"
enable_slack_integration = false

# Development Configuration
enable_development_features = true
enable_debug_mode          = true
enable_testing_features    = true
enable_performance_testing = true

# Network Security (Optional - for development access)
# development_ip_whitelist = [
#   "203.0.113.0/24",  # Office network
#   "198.51.100.0/24"  # VPN network
# ]

# Cost Configuration
development_budget_limit = 500   # Total monthly budget for dev environment
bedrock_budget_limit    = 200   # Bedrock-specific budget

# Resource Sizing (Optimized for Development)
resource_sizing = {
  vpc_endpoints_count    = 3   # Minimal set: Bedrock Runtime, Bedrock Management, CloudWatch Logs
  availability_zones     = 2   # Two AZs sufficient for development
  log_retention_days     = 30  # One month retention for cost optimization
  metric_retention_days  = 90  # Three months for performance analysis
}

# Monitoring Configuration
monitoring_level = "detailed"      # Options: basic, detailed, comprehensive
alert_frequency  = "immediate"     # Options: immediate, hourly, daily

# Compliance Configuration (Relaxed for Development)
compliance_level     = "development"  # Options: development, staging, production
data_classification  = "Internal"     # Options: Public, Internal, Confidential, Restricted
enable_audit_logging = true          # Always keep audit logging enabled

# Feature Flags
feature_flags = {
  advanced_security_processing = true   # Test advanced security features
  custom_metrics_collection   = true   # Enable custom business metrics
  ai_model_monitoring        = true   # Monitor AI model performance
  cost_optimization_alerts   = true   # Enable cost monitoring
  performance_analytics      = true   # Enable detailed performance tracking
}

# Deployment Configuration
deployment_mode           = "development"  # Options: development, testing, integration
auto_scaling_enabled     = false          # Not needed for development
high_availability_enabled = false          # Not needed for development

# Testing Configuration
testing_data_retention_days = 7  # Keep testing data for one week

# Network Configuration (Optional Override)
# vpc_cidr_override = "10.100.0.0/16"  # Custom VPC CIDR if needed
enable_vpc_flow_logs = true

# Additional Tags (Optional)
additional_tags = {
  Purpose         = "SecurityAgents-Development"
  Team           = "Alpha-1-Infrastructure"
  Phase          = "2A-Implementation"
  CostCenter     = "Security-Development"
  Project        = "SecurityAgents"
  Owner          = "security-team@company.com"
  Environment    = "dev"
  Compliance     = "Internal"
  BusinessUnit   = "Security-Operations"
}

# Environment-Specific Overrides (Advanced)
environment_overrides = {
  # Add any environment-specific configuration overrides here
  # Example:
  # "enable_experimental_features" = true
  # "custom_log_retention_days" = 14
}

# Examples of what to modify for your environment:
# 
# 1. Replace all email addresses with your team's actual emails
# 2. Replace IAM ARNs with your actual user/role ARNs  
# 3. Set your preferred AWS region (must support Bedrock)
# 4. Adjust budget limits based on your requirements
# 5. Configure Slack webhook if you want Slack notifications
# 6. Add your office/VPN IP ranges to development_ip_whitelist if needed
# 7. Customize tags to match your organization's standards