// CrowdStrike Falcon LogScale Queries for IAM Security Analytics
// Prepared for Panther -> CrowdStrike migration

//==============================================================================
// 1. CREDENTIAL STUFFING DETECTION
//==============================================================================

// Basic credential stuffing pattern detection
#repo=okta_logs
| eventtype="user.authentication.sso" 
| outcome.result="FAILURE"
| groupBy([client.ipAddress], function=[
    count() as failed_attempts,
    values(actor.alternateId) as targeted_users,
    min(@timestamp) as first_attempt,
    max(@timestamp) as last_attempt
  ])
| failed_attempts >= 5
| span := last_attempt - first_attempt
| span <= 5m
| unique_users := length(targeted_users)
| unique_users >= 3
| sort(failed_attempts, order=desc)

// Advanced credential stuffing with geo-analysis
#repo=okta_logs
| eventtype="user.authentication.sso"
| outcome.result="FAILURE"
| groupBy([client.ipAddress], function=[
    count() as attempts,
    values(actor.alternateId) as users,
    values(client.geographicalContext.country) as countries,
    values(client.geographicalContext.city) as cities,
    min(@timestamp) as start_time,
    max(@timestamp) as end_time
  ])
| attempts >= 5
| duration := end_time - start_time
| duration <= 10m
| unique_users := length(users)
| unique_countries := length(countries)
| unique_cities := length(cities)
| unique_users >= 3
| eval(risk_score = case {
    unique_countries > 1 => 0.8;
    unique_cities > 2 => 0.7;
    duration <= 1m => 0.9;
    * => 0.6
  })
| risk_score >= 0.6

//==============================================================================
// 2. PRIVILEGE ESCALATION DETECTION
//==============================================================================

// Group membership changes to privileged groups
#repo=okta_logs
| eventtype="group.user_membership.add"
| target{}.displayName in ["Super Admins", "Application Admins", "Security Admins", "Directory Admins"]
| groupBy([actor.alternateId], function=[
    count() as escalation_count,
    values(target{}.displayName) as privilege_groups,
    values(client.geographicalContext.country) as countries,
    min(@timestamp) as first_escalation,
    max(@timestamp) as last_escalation
  ])
| escalation_count >= 1
| eval(off_hours = case {
    strftime("%H", first_escalation) < "08" => true;
    strftime("%H", first_escalation) >= "18" => true;
    strftime("%w", first_escalation) in ["0", "6"] => true;
    * => false
  })
| eval(severity = case {
    "Super Admins" in privilege_groups => "CRITICAL";
    "Security Admins" in privilege_groups => "HIGH";
    off_hours = true => "HIGH";
    * => "MEDIUM"
  })

// Application privilege assignments
#repo=okta_logs
| eventtype="application.user_membership.add"
| target{}.displayName in ["AWS SSO", "Azure AD", "Google Workspace Admin", "GitHub Enterprise"]
| groupBy([actor.alternateId, target{}.displayName], function=[
    count() as assignment_count,
    values(client.ipAddress) as source_ips,
    min(@timestamp) as first_assignment
  ])
| eval(risk_factors = [])
| eval(risk_factors = case {
    length(source_ips) > 1 => risk_factors + ["multiple_ips"];
    * => risk_factors
  })
| eval(risk_factors = case {
    strftime("%H", first_assignment) < "08" or strftime("%H", first_assignment) >= "18" => risk_factors + ["off_hours"];
    * => risk_factors
  })
| length(risk_factors) > 0

//==============================================================================
// 3. ACCOUNT TAKEOVER DETECTION
//==============================================================================

// Behavioral anomaly detection for successful logins
#repo=okta_logs
| eventtype="user.authentication.sso"
| outcome.result="SUCCESS"
| groupBy([actor.alternateId], function=[
    count() as login_count,
    values(client.geographicalContext.country) as countries,
    values(client.geographicalContext.city) as cities,
    values(client.device) as devices,
    values(strftime("%H", @timestamp)) as login_hours,
    min(@timestamp) as session_start,
    max(@timestamp) as session_end
  ], limit=10000)
| unique_countries := length(countries)
| unique_cities := length(cities) 
| unique_devices := length(devices)
| unique_hours := length(login_hours)
| session_duration := session_end - session_start
| eval(behavioral_anomalies = [])
| eval(behavioral_anomalies = case {
    unique_countries > 2 => behavioral_anomalies + ["geo_anomaly"];
    * => behavioral_anomalies
  })
| eval(behavioral_anomalies = case {
    unique_cities > 5 => behavioral_anomalies + ["city_hopping"];
    * => behavioral_anomalies
  })
| eval(behavioral_anomalies = case {
    unique_devices > 3 => behavioral_anomalies + ["device_anomaly"];
    * => behavioral_anomalies
  })
| eval(behavioral_anomalies = case {
    session_duration < 1m and login_count > 10 => behavioral_anomalies + ["rapid_sessions"];
    * => behavioral_anomalies
  })
| length(behavioral_anomalies) >= 2

// Impossible travel detection
#repo=okta_logs
| eventtype="user.authentication.sso"
| outcome.result="SUCCESS"
| sort(@timestamp)
| groupBy([actor.alternateId], function=[
    array_agg([client.geographicalContext.city, @timestamp]) as login_events
  ])
| mv_expand(login_events)
| rename("login_events[0]" as city, "login_events[1]" as login_time)
| sort(login_time)
| groupBy([actor.alternateId], function=[
    array_agg([city, login_time]) as ordered_logins
  ])
// Note: Full impossible travel requires geographic distance calculation
// This would be enhanced with custom functions for distance/speed calculations

//==============================================================================
// 4. LATERAL MOVEMENT DETECTION
//==============================================================================

// Cross-application access patterns
#repo=okta_logs
| eventtype="app.generic.provision.activate"
| groupBy([actor.alternateId], function=[
    count() as app_accesses,
    values(target{}.displayName) as applications,
    min(@timestamp) as first_access,
    max(@timestamp) as last_access
  ], span=1h)
| unique_apps := length(applications)
| access_duration := last_access - first_access
| unique_apps >= 5
| access_duration <= 1h
| eval(lateral_movement_score = case {
    unique_apps >= 10 and access_duration <= 30m => 0.9;
    unique_apps >= 8 and access_duration <= 45m => 0.8;
    unique_apps >= 5 and access_duration <= 1h => 0.7;
    * => 0.5
  })
| lateral_movement_score >= 0.7

// Privileged account lateral movement
#repo=okta_logs
| eventtype in ["app.generic.provision.activate", "user.authentication.sso"]
| outcome.result="SUCCESS"
| regex(actor.alternateId, pattern="admin|service|root", flags=i)
| groupBy([actor.alternateId], function=[
    count() as access_count,
    values(target{}.displayName) as resources,
    values(client.ipAddress) as source_ips,
    min(@timestamp) as movement_start,
    max(@timestamp) as movement_end
  ], span=2h)
| unique_resources := length(resources)
| unique_ips := length(source_ips)
| movement_duration := movement_end - movement_start
| unique_resources >= 3
| eval(privilege_level = case {
    regex(actor.alternateId, pattern="super|root", flags=i) => "super";
    regex(actor.alternateId, pattern="admin", flags=i) => "admin";
    regex(actor.alternateId, pattern="service", flags=i) => "service";
    * => "standard"
  })

//==============================================================================
// 5. INSIDER THREAT DETECTION
//==============================================================================

// Data access anomalies
#repo=okta_logs
| eventtype="app.generic.provision.activate"
| target{}.displayName in ["Salesforce", "SharePoint", "Box", "Google Drive", "Confluence"]
| groupBy([actor.alternateId], function=[
    count() as access_count,
    values(target{}.displayName) as data_sources,
    values(strftime("%H", @timestamp)) as access_hours,
    values(strftime("%w", @timestamp)) as access_days
  ], span=24h)
| unique_sources := length(data_sources)
| unique_hours := length(access_hours)
| unique_days := length(access_days)
| eval(off_hours_accesses = 0)
| mv_expand(access_hours)
| eval(off_hours_accesses = case {
    access_hours < "08" or access_hours >= "18" => off_hours_accesses + 1;
    * => off_hours_accesses
  })
| eval(weekend_accesses = 0)
| mv_expand(access_days)
| eval(weekend_accesses = case {
    access_days in ["0", "6"] => weekend_accesses + 1;
    * => weekend_accesses
  })
| off_hours_percentage := (off_hours_accesses / access_count) * 100
| weekend_percentage := (weekend_accesses / access_count) * 100
| eval(insider_risk_score = 0)
| eval(insider_risk_score = case {
    off_hours_percentage > 50 => insider_risk_score + 0.4;
    off_hours_percentage > 30 => insider_risk_score + 0.2;
    * => insider_risk_score
  })
| eval(insider_risk_score = case {
    weekend_percentage > 30 => insider_risk_score + 0.3;
    weekend_percentage > 15 => insider_risk_score + 0.1;
    * => insider_risk_score
  })
| eval(insider_risk_score = case {
    unique_sources >= 5 => insider_risk_score + 0.2;
    unique_sources >= 3 => insider_risk_score + 0.1;
    * => insider_risk_score
  })
| eval(insider_risk_score = case {
    access_count > 100 => insider_risk_score + 0.1;
    * => insider_risk_score
  })
| insider_risk_score >= 0.6

// Privileged user behavior monitoring
#repo=okta_logs
| eventtype in ["user.lifecycle.create", "user.lifecycle.deactivate", "group.user_membership.add", "group.user_membership.remove"]
| regex(actor.alternateId, pattern="admin|super|root", flags=i)
| groupBy([actor.alternateId], function=[
    count() as admin_actions,
    values(eventtype) as action_types,
    values(target{}.alternateId) as affected_users,
    min(@timestamp) as first_action,
    max(@timestamp) as last_action
  ], span=1h)
| unique_action_types := length(action_types)
| unique_users := length(affected_users)
| action_duration := last_action - first_action
| eval(bulk_operation = case {
    admin_actions > 10 and action_duration <= 10m => true;
    unique_users > 5 and action_duration <= 30m => true;
    * => false
  })
| eval(off_hours = case {
    strftime("%H", first_action) < "08" => true;
    strftime("%H", first_action) >= "18" => true;
    strftime("%w", first_action) in ["0", "6"] => true;
    * => false
  })
| bulk_operation = true or off_hours = true

//==============================================================================
// 6. ADVANCED ANALYTICS AND SCORING
//==============================================================================

// Multi-dimensional risk scoring
#repo=okta_logs
| eventtype="user.authentication.sso"
| outcome.result="SUCCESS"
| groupBy([actor.alternateId], function=[
    count() as login_count,
    values(client.geographicalContext.country) as countries,
    values(client.device) as devices,
    values(client.ipAddress) as ip_addresses,
    count_distinct(client.geographicalContext.country) as unique_countries,
    count_distinct(client.device) as unique_devices,
    count_distinct(client.ipAddress) as unique_ips,
    min(@timestamp) as first_login,
    max(@timestamp) as last_login
  ], span=24h)
| session_span := last_login - first_login
| eval(geo_risk = case {
    unique_countries > 3 => 0.8;
    unique_countries > 1 => 0.5;
    * => 0.1
  })
| eval(device_risk = case {
    unique_devices > 5 => 0.7;
    unique_devices > 2 => 0.4;
    * => 0.1
  })
| eval(ip_risk = case {
    unique_ips > 10 => 0.8;
    unique_ips > 5 => 0.5;
    * => 0.1
  })
| eval(velocity_risk = case {
    login_count > 50 and session_span <= 1h => 0.9;
    login_count > 30 and session_span <= 2h => 0.6;
    login_count > 20 and session_span <= 4h => 0.4;
    * => 0.1
  })
| composite_risk_score := (geo_risk * 0.3) + (device_risk * 0.2) + (ip_risk * 0.2) + (velocity_risk * 0.3)
| composite_risk_score >= 0.6

// Time series anomaly detection preparation
#repo=okta_logs
| eventtype="user.authentication.sso"
| outcome.result="SUCCESS"
| timechart(span=1h, function=[
    count() as login_count,
    count_distinct(actor.alternateId) as unique_users,
    count_distinct(client.ipAddress) as unique_ips
  ])
| eval(login_rate = login_count / 3600)  // Logins per second
// Note: Statistical anomaly detection would be implemented with custom functions

//==============================================================================
// 7. THREAT HUNTING QUERIES
//==============================================================================

// Hunt for credential stuffing campaigns
#repo=okta_logs
| eventtype="user.authentication.sso"
| outcome.result="FAILURE"
| timechart(span=5m, function=[
    count() as failures,
    count_distinct(actor.alternateId) as unique_users,
    count_distinct(client.ipAddress) as unique_ips
  ])
| failures > 100
| failure_rate := failures / unique_users
| failure_rate > 5

// Hunt for privilege escalation campaigns
#repo=okta_logs  
| eventtype in ["group.user_membership.add", "application.user_membership.add"]
| target{}.displayName in ["Super Admins", "Application Admins", "Security Admins", "AWS SSO", "Azure AD"]
| timechart(span=1h, function=[
    count() as escalations,
    count_distinct(actor.alternateId) as escalating_users,
    count_distinct(target{}.alternateId) as target_users
  ])
| escalations > 5
| escalation_efficiency := escalations / escalating_users
| escalation_efficiency > 2

// Hunt for account takeover indicators
#repo=okta_logs
| eventtype="user.authentication.sso" 
| outcome.result="SUCCESS"
| groupBy([actor.alternateId], function=[
    count() as login_count,
    count_distinct(client.geographicalContext.country) as countries,
    count_distinct(client.device) as devices,
    values(client.geographicalContext.country) as country_list,
    min(@timestamp) as first_seen,
    max(@timestamp) as last_seen
  ], span=6h)
| countries > 2
| devices > 3  
| login_count > 20
| activity_span := last_seen - first_seen
| activity_span <= 2h

//==============================================================================
// 8. REAL-TIME ALERTING QUERIES
//==============================================================================

// Real-time credential stuffing alert
#repo=okta_logs
| eventtype="user.authentication.sso"
| outcome.result="FAILURE"
| groupBy([client.ipAddress], function=[count() as failures], span=1m)
| failures >= 10
| eval(alert_level = "HIGH")
| eval(alert_type = "credential_stuffing")
| eval(recommended_action = "Block source IP and investigate")

// Real-time privilege escalation alert  
#repo=okta_logs
| eventtype="group.user_membership.add"
| target{}.displayName="Super Admins"
| eval(alert_level = "CRITICAL") 
| eval(alert_type = "super_admin_escalation")
| eval(recommended_action = "Immediate verification required")

// Real-time impossible travel alert
#repo=okta_logs
| eventtype="user.authentication.sso"
| outcome.result="SUCCESS"
// This would include geographic distance/time calculations
| eval(alert_level = "MEDIUM")
| eval(alert_type = "impossible_travel")
| eval(recommended_action = "Verify user location and session validity")